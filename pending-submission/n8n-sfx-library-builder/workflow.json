      "parameters": {
        "content": "## Select the queued batch\nKeeps only Queued or blank rows, caps the batch, and clamps duration and prompt influence. Edit the tunables at the top of the node.",
        "color": 7,
        "width": 268,
        "height": 384
      }
    },
