            { "id": "b1", "name": "replyBody", "value": "={{ $('Draft Grounded Reply').item.json.text }}\n\nSources:\n{{ $('Bundle Retrieved Sources').item.json.sourcesList }}", "type": "string" },
            { "id": "b2", "name": "senderEmail", "value": "={{ $('Bundle Retrieved Sources').item.json.senderEmail }}", "type": "string" },
            { "id": "b3", "name": "threadId", "value": "={{ $('Bundle Retrieved Sources').item.json.threadId }}", "type": "string" },
            { "id": "b4", "name": "emailSubject", "value": "={{ $('Bundle Retrieved Sources').item.json.emailSubject }}", "type": "string" }
          ]
        },
        "options": {}
      }
