    {
      "id": "95babe45-8bbd-4238-8628-09c21c4c49f7",
      "name": "Get Article Body",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2.2,
      "position": [464, 272],
      "parameters": {
        "resource": "block",
        "operation": "getAll",
        "blockId": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $json.id }}"
        },
        "returnAll": true
      },
      "onError": "continueRegularOutput"
