          "mode": "list",
          "cachedResultName": "Tasks"
        },
        "options": {}
      },
      "id": "a1b2c3d4-0005-4a00-8000-000000000005",
      "name": "Read Existing Rows in Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [
        480,
        420
      ],
      "onError": "continueRegularOutput",
      "credentials": {
