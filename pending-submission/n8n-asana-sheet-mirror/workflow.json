        "color": 7
      },
      "id": "a1b2c3d4-00f4-4a00-8000-0000000000f4",
      "name": "Sticky Write",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        1560,
        40
      ]
    }
