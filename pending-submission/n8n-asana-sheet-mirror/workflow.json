      "name": "Fetch Asana Tasks",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        448,
        0
      ],
      "parameters": {
        "method": "GET",
        "url": "=https://app.asana.com/api/1.0/projects/{{ $json.asana_project_gid }}/tasks",
