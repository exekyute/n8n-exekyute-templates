      "typeVersion": 1.1,
      "position": [780, 300],
      "webhookId": "c8f2d1b3-4e55-4a66-8b77-88d1b2c3d4e5"
    },
    {
      "parameters": {
        "url": "={{ $('Start Gladia Translation').item.json.result_url }}",
