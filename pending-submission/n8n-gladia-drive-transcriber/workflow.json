      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "// Build a Markdown transcript file from Gladia's result.\n// Runs once per completed transcription (the Route by Status \"done\" output).\n\nconst result = $json.result || {};\nconst transcription = result.transcription || {};\n\nconst fullTranscript = (transcription.full_transcript || '').trim();\nconst utterances = Array.isArray(transcription.utterances) ? transcription.utterances : [];\n\n// Duration can sit in a couple of places depending on the response shape.\nconst duration =\n  result.metadata?.audio_duration ??\n  $json.file?.audio_duration ??\n  $('Upload Audio to Gladia').item.json.audio_metadata?.audio_duration ??\n  null;\n\nconst sourceName = $('Google Drive Audio Trigger').item.json.name || 'audio-file';\nconst baseName = sourceName.replace(/\\.[^/.]+$/, '');\nconst stamp = $now.toFormat('yyyyLLdd-HHmmss');\nconst fileName = baseName + '-transcript-' + stamp + '.md';\n\n// Assemble a readable Markdown document. Speaker-labelled lines when Gladia\n// returns utterances, otherwise the plain full transcript.\nlet body = '# Transcript: ' + sourceName + '\\n\\n';\nbody += '- Source file: ' + sourceName + '\\n';\nbody += '- Duration: ' + (duration != null ? duration + ' seconds' : 'unknown') + '\\n';\nbody += '- Transcribed: ' + $now.toISO() + '\\n\\n---\\n\\n';\n\nif (utterances.length) {\n  for (const u of utterances) {\n    const who = (u.speaker !== undefined && u.speaker !== null) ? ('Speaker ' + u.speaker) : 'Speaker';\n    body += '**' + who + ':** ' + (u.text || '').trim() + '\\n\\n';\n  }\n} else {\n  body += (fullTranscript || '(No transcript text was returned.)') + '\\n';\n}\n\nconst preview = fullTranscript.slice(0, 180);\n\nreturn {\n  json: {\n    source_file: sourceName,\n    audio_duration: duration,\n    file_name: fileName,\n    preview: preview,\n    status: 'Transcribed',\n  },\n  binary: {\n    data: {\n      data: Buffer.from(body, 'utf-8').toString('base64'),\n      mimeType: 'text/markdown',\n      fileName: fileName,\n      fileExtension: 'md',\n    },\n  },\n};"
      },
