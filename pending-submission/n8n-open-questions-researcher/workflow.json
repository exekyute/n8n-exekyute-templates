      ],
      "credentials": {
        "notionApi": {
          "id": "REPLACE_WITH_YOUR_NOTION_CREDENTIAL",
          "name": "Notion account"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 1
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "cond-question",
              "leftValue": "={{ $json['Question'] }}",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              },
              "rightValue": ""
            },
            {
              "id": "cond-status",
              "leftValue": "={{ $json['Status'] }}",
              "operator": {
                "type": "string",
                "operation": "equals"
              },
              "rightValue": "To Research"
            }
          ]
        },
        "options": {}
      },
      "id": "d634b4ac-7c6e-4bb1-9817-ef27e8355438",
      "name": "If Row Needs Research",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        288,
        736
      ]
    },
    {
      "parameters": {
        "operation": "research",
        "input": "={{ $('When a Question Is Added').item.json['Question'] }}"
