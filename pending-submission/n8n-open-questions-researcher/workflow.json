{
  "name": "Answer a Notion questions queue in place using You.com research",
  "nodes": [
    {
      "parameters": {
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "databaseId": {
          "__rl": true,
          "mode": "id",
          "value": "REPLACE_WITH_QUESTIONS_DATABASE_ID"
        }
      },
      "id": "14bffe39-57ae-4716-9089-31042921d546",
      "name": "When a Question Is Added",
