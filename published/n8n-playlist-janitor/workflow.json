              "name": "privacyStatus",
              "value": "={{ $json.status?.privacyStatus || 'unknown' }}",
              "type": "string"
            },
            {
              "id": "l6",
              "name": "videoFound",
              "value": "={{ !!$json.id }}",
              "type": "boolean"
            }
          ]
        },
        "options": {}
