    {
      "parameters": {
        "options": {}
      },
      "id": "d8d2f9a0-0194-4c0b-bddf-2a402ef23abe",
      "name": "Loop Items to Remove",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        2064,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "const cfg = $('Set Playlist and Options').first().json;\nconst dryRun = cfg.dryRun !== false;\nconst rows = $input.all().map(function (i) { return i.json; });\nconst flagged = rows.filter(function (r) { return r.flagged; });\nconst dead = flagged.filter(function (r) { return r.isDead; });\nconst dupes = flagged.filter(function (r) { return r.isDuplicate && !r.isDead; });\nconst lines = flagged.map(function (r) {\n  return \"- \" + (r.title || \"(no title)\") + \" (\" + (r.videoId || \"no id\") + \") - \" + r.reason;\n}).join(\"\\n\");\nconst verb = dryRun ? \"would be removed\" : \"removed\";\nlet text;\nif (flagged.length === 0) {\n  text = \"Playlist Janitor: playlist is clean. Checked \" + rows.length + \" item(s), nothing to remove.\";\n} else {\n  const mode = dryRun ? \"DRY RUN (report only, nothing deleted)\" : \"LIVE RUN (items deleted)\";\n  text = \"Playlist Janitor - \" + mode + \"\\n\"\n    + \"Checked \" + rows.length + \" item(s). \" + flagged.length + \" \" + verb + \": \"\n    + dead.length + \" dead, \" + dupes.length + \" duplicate.\\n\\n\" + lines;\n}\nreturn [{ json: {\n  summary: text,\n  checked: rows.length,\n  flaggedCount: flagged.length,\n  deadCount: dead.length,\n  duplicateCount: dupes.length,\n  dryRun: dryRun\n} }];"
      },
      "id": "19c2d91b-cd42-4853-8917-455b8931219e",
      "name": "Build Cleanup Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
