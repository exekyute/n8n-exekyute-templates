      "id": "f4c07bc6-b0b8-43c0-b48e-6ef0c16b7de2",
      "name": "Mark Live Videos",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1120,
        224
      ]
    },
    {
      "parameters": {
        "jsCode": "const cfg = $('Set Playlist and Options').first().json;\nconst dryRun = cfg.dryRun !== false;\nconst rows = $input.all().map(function (i) { return i.json; });\nrows.sort(function (a, b) { return (Number(a.position) || 0) - (Number(b.position) || 0); });\nconst seen = {};\nconst out = [];\nfor (const r of rows) {\n  const videoId = r.videoId || \"\";\n  const privacy = String(r.privacyStatus || \"\").toLowerCase();\n  const videoFound = r.videoFound === true || r.videoFound === \"true\";\n  const isDead = !videoFound || privacy === \"private\" || privacy === \"privacystatusunspecified\";\n  let isDuplicate = false;\n  if (videoId) {\n    if (seen[videoId]) isDuplicate = true;\n    else seen[videoId] = true;\n  }\n  const reasons = [];\n  if (isDead) reasons.push(videoFound ? \"Private video\" : \"Deleted or unavailable video\");\n  if (isDuplicate) reasons.push(\"Duplicate entry\");\n  const flagged = isDead || isDuplicate;\n  out.push({ json: {\n    playlistItemId: r.playlistItemId,\n    videoId: videoId,\n    title: r.title || \"(no title)\",\n    position: r.position,\n    privacyStatus: r.privacyStatus || \"\",\n    videoFound: videoFound,\n    isDead: isDead,\n    isDuplicate: isDuplicate,\n    flagged: flagged,\n    toDelete: flagged && !dryRun,\n    reason: reasons.join(\" and \") || \"Active\",\n    dryRun: dryRun,\n    liveRun: !dryRun\n  } });\n}\nreturn out;"
      },
      "id": "c030d71a-e645-475f-b981-820810d8fd9e",
      "name": "Flag Duplicates and Dead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
